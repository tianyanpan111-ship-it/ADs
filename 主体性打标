def find_column(df: pd.DataFrame, explicit: Optional[str], candidates: Sequence[str], kind: str) -> str:
    if explicit:
        if explicit not in df.columns:
            raise KeyError(f"Cannot find {kind} column '{explicit}'. Available columns: {df.columns.tolist()}")
        return explicit

    lowered = {str(col).strip().lower(): col for col in df.columns}
    for candidate in candidates:
        for lowered_name, original in lowered.items():
            if candidate.lower() in lowered_name:
                return original

    raise KeyError(f"Cannot auto-detect {kind} column. Available columns: {df.columns.tolist()}")


def sanitize_value(value) -> str:
    if pd.isna(value):
        return ""
    return str(value).strip()


def parse_binary_label(value) -> Optional[int]:
    if pd.isna(value):
        return None

    if isinstance(value, (int, float)) and not pd.isna(value):
        number = int(float(value))
        if number in {0, 1}:
            return number

    text = str(value).strip().casefold()
    if text in {"0", "low", "low agency", "false", "no", "n", "negative", "低", "低主体性", "低主體性"}:
        return 0
    if text in {"1", "high", "high agency", "true", "yes", "y", "positive", "高", "高主体性", "高主體性"}:
        return 1

    try:
        number = int(float(text))
        if number in {0, 1}:
            return number
    except Exception:
        pass

    if any(token in text for token in ["低", "low"]):
        return 0
    if any(token in text for token in ["高", "high"]):
        return 1

    return None


def to_optional_float(value) -> Optional[float]:
    if pd.isna(value):
        return None
    try:
        return float(value)
    except Exception:
        return None


def normalize_text_for_match(text: str) -> str:
    return text.casefold().strip()

