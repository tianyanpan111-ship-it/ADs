def parse_model_json(text: str) -> Dict:
    # 移除 Markdown 代码块标记
    text = re.sub(r"```json|```", "", text, flags=re.I).strip()

    # 提取第一个 JSON 对象
    m = re.search(r"\{.*\}", text, flags=re.S)
    if not m:
        raise ValueError(f"Cannot locate JSON in model output: {text[:300]}")

    data = json.loads(m.group(0))
    if not isinstance(data, dict):
        raise ValueError("Model output JSON is not an object")
    return data

def normalize_prediction(data: Dict) -> Dict:
    continuous = data.get("continuous_score", None)
    confidence = data.get("confidence", 0)
    rationale = data.get("rationale", "")

    if continuous is None:
        continuous_score = None
    else:
        try:
            continuous_score = round(float(continuous), 1)
        except Exception:
            continuous_score = None

    if continuous_score is None:
        binary_score = None
    else:
        # binary label is intentionally omitted; caller will use continuous_score only
        binary_score = None

    try:
        confidence_value = float(confidence)
    except Exception:
        confidence_value = 0.0
    confidence_value = max(0.0, min(1.0, confidence_value))

    if rationale is None:
        rationale_text = ""
    else:
        rationale_text = str(rationale).strip()

    return {
        "continuous_score": continuous_score,
        "confidence": confidence_value,
        "rationale": rationale_text,
    }


def call_openrouter(api_key: str, model: str, image_path: Path, temperature: float, max_tokens: int, openrouter_referer: str, openrouter_title: str, retry_times: int) -> Dict:
    if not api_key:
        raise ValueError("Missing OpenRouter API key. Set OPENROUTER_API_KEY or pass --api-key.")

    image_bytes = ensure_rgb_bytes(image_path)
    image_data_uri = image_bytes_to_data_uri(image_bytes)
    payload = build_payload(model, image_data_uri, temperature, max_tokens)

    headers = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
    }
    if openrouter_referer:
        headers["HTTP-Referer"] = openrouter_referer
    if openrouter_title:
        headers["X-Title"] = openrouter_title

    last_error = None
    attempts = max(1, int(retry_times) + 1)
    for attempt in range(1, attempts + 1):
        try:
            response = requests.post(OPENROUTER_CHAT_URL, headers=headers, json=payload, timeout=90)
            response.raise_for_status()
            data = response.json()

            choices = data.get("choices") or []
            if not choices:
                raise ValueError(f"No choices in response: {data}")

            message = choices[0].get("message", {})
            content = message.get("content", "")
            if not isinstance(content, str):
                content = json.dumps(content, ensure_ascii=False)

            parsed = parse_model_json(content)
            return normalize_prediction(parsed)
        except Exception as exc:
            last_error = exc
            logging.warning("API attempt %s/%s failed for %s: %s", attempt, attempts, image_path.name, exc)
            if attempt < attempts:
                time.sleep(2 ** attempt)

    raise RuntimeError(f"OpenRouter call failed for {image_path.name}: {last_error}")


def load_checkpoint(checkpoint_path: Path) -> pd.DataFrame:
    if checkpoint_path.exists():
        return pd.read_csv(checkpoint_path)
    return pd.DataFrame()


def save_checkpoint(checkpoint_path: Path, rows: List[Dict]) -> None:
    df = pd.DataFrame(rows)
    df.to_csv(checkpoint_path, index=False, encoding="utf-8-sig")


def compute_icc_two_way_absolute_agreement(human_scores: Sequence[float], model_scores: Sequence[float]) -> float:
    pairs = [(float(h), float(m)) for h, m in zip(human_scores, model_scores) if pd.notna(h) and pd.notna(m)]
    n = len(pairs)
    if n < 2:
        return float("nan")

    data = pd.DataFrame(pairs, columns=["human", "model"])
    grand_mean = data.values.mean()
    row_means = data.mean(axis=1)
    col_means = data.mean(axis=0)

    k = 2
    ssr = k * ((row_means - grand_mean) ** 2).sum()
    ssc = n * ((col_means - grand_mean) ** 2).sum()
    sst = ((data - grand_mean) ** 2).to_numpy().sum()
    sse = sst - ssr - ssc

    msr = ssr / (n - 1)
    msc = ssc / (k - 1)
    mse = sse / ((n - 1) * (k - 1))

    denominator = msr + (k - 1) * mse + (k * (msc - mse) / n)
    if denominator == 0:
        return float("nan")
    return (msr - mse) / denominator


def compute_binary_metrics(human_binary: Sequence[int], model_binary: Sequence[int]) -> Dict[str, float]:
    pairs = [(int(h), int(m)) for h, m in zip(human_binary, model_binary) if h in {0, 1} and m in {0, 1}]
    n = len(pairs)
    if n == 0:
        return {
            "kappa": float("nan"),
            "precision": float("nan"),
            "recall": float("nan"),
            "f1": float("nan"),
            "accuracy": float("nan"),
        }

    tp = sum(1 for h, m in pairs if h == 1 and m == 1)
    tn = sum(1 for h, m in pairs if h == 0 and m == 0)
    fp = sum(1 for h, m in pairs if h == 0 and m == 1)
    fn = sum(1 for h, m in pairs if h == 1 and m == 0)

    accuracy = (tp + tn) / n
    precision = tp / (tp + fp) if (tp + fp) else float("nan")
    recall = tp / (tp + fn) if (tp + fn) else float("nan")
    if precision == precision and recall == recall and (precision + recall):
        f1 = 2 * precision * recall / (precision + recall)
    else:
        f1 = float("nan")

    human_pos = (tp + fn) / n
    human_neg = (tn + fp) / n
    model_pos = (tp + fp) / n
    model_neg = (tn + fn) / n
    pe = human_pos * model_pos + human_neg * model_neg
    po = accuracy
    kappa = (po - pe) / (1 - pe) if (1 - pe) else float("nan")

    return {
        "kappa": kappa,
        "precision": precision,
        "recall": recall,
        "f1": f1,
        "accuracy": accuracy,
    }


def build_summary_df(checkpoint_df: pd.DataFrame) -> pd.DataFrame:
    valid_continuous = checkpoint_df[checkpoint_df["continuous_score"].notna() & checkpoint_df["human_continuous"].notna()]

    icc = compute_icc_two_way_absolute_agreement(
        valid_continuous["human_continuous"].tolist(),
        valid_continuous["continuous_score"].tolist(),
    )

    total = len(checkpoint_df)
    scored = int(checkpoint_df["continuous_score"].notna().sum()) if total else 0
    error_count = 0
    if "error_message" in checkpoint_df.columns:
        error_series = checkpoint_df["error_message"].fillna("").astype(str)
        error_count = int((error_series.str.strip() != "").sum())

    summary_rows = [
        {"metric": "n_images", "value": total},
        {"metric": "n_with_continuous_score", "value": scored},
        {"metric": "n_errors", "value": error_count},
        {"metric": "ICC(2,1)_continuous", "value": icc},
    ]
    return pd.DataFrame(summary_rows)

