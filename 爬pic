def get_pic_urls(html: str):
    soup = BeautifulSoup(html, 'html.parser')
    urls = [tag['content'] for tag in soup.find_all('meta', attrs={'name': 'og:image'}) if tag.get('content')]
    if not urls:
        for img in soup.select('img'):
            src = img.get('src') or img.get('data-src')
            if src and src.startswith('http'):
                urls.append(src)
    return list(dict.fromkeys(urls))


def get_note_id_from_url(note_url: str) -> str:
