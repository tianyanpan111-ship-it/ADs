def extract_note_type_from_initial_state(html: str, note_id: str) -> str:
    if not html or not note_id:
        return ''

    note_anchor = f'"noteId":"{note_id}"'
    start = 0
    found_note_segment = False
    while True:
        idx = html.find(note_anchor, start)
        if idx == -1:
            break

        segment = html[max(0, idx - 2000): idx + 15000]
        has_interact = '"interactInfo":{' in segment
        has_video = ('"video":{' in segment) or ('"type":"video"' in segment)

        if has_interact:
            found_note_segment = True
            if has_video:
                return '视频'

        start = idx + len(note_anchor)

    if found_note_segment:
        return '图文'
    return ''


