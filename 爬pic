def get_baidu_access_token():
    global BAIDU_ACCESS_TOKEN, BAIDU_TOKEN_EXPIRES_AT
    if BAIDU_ACCESS_TOKEN and time.time() < BAIDU_TOKEN_EXPIRES_AT - 60:
        return BAIDU_ACCESS_TOKEN
    if not BAIDU_API_KEY or not BAIDU_SECRET_KEY:
        raise ValueError('请先填写 BAIDU_API_KEY 和 BAIDU_SECRET_KEY')

    params = {
        'grant_type': 'client_credentials',
        'client_id': BAIDU_API_KEY,
        'client_secret': BAIDU_SECRET_KEY,
    }
    response = requests.get(BAIDU_OAUTH_URL, params=params, timeout=10)
    response.raise_for_status()
    data = response.json()
    access_token = data.get('access_token')
    expires_in = data.get('expires_in', 2592000)
    if not access_token:
        raise ValueError(f'获取百度 access_token 失败: {data}')

    BAIDU_ACCESS_TOKEN = access_token
    BAIDU_TOKEN_EXPIRES_AT = time.time() + int(expires_in)
    return BAIDU_ACCESS_TOKEN


def analyze_face_with_baidu(image_bytes: bytes):
    token = get_baidu_access_token()
    url = f'{BAIDU_FACE_DETECT_URL}?access_token={token}'
    image_base64 = base64.b64encode(image_bytes).decode('utf-8')
    payload = {
        'image': image_base64,
        'image_type': 'BASE64',
        'face_field': 'gender,face_probability',
        'max_face_num': 5,
        'face_type': 'LIVE',
        'quality_control': 'NONE',
    }
    headers = {'Content-Type': 'application/json'}
    response = requests.post(url, headers=headers, json=payload, timeout=20)
    response.raise_for_status()
    data = response.json()
    if data.get('error_code', 0) != 0:
        raise ValueError(f'百度人脸检测失败 {data.get("error_code")}: {data.get("error_msg")}')
    face_list = data.get('result', {}).get('face_list', [])
    if face_list is None:
        raise ValueError(f'百度人脸检测结果解析失败: {data}')
    return face_list


def convert_image_to_jpeg_bytes(image_bytes: bytes):
    with Image.open(io.BytesIO(image_bytes)) as img:
        if img.mode != 'RGB':
            img = img.convert('RGB')
        if max(img.size) > MAX_BAIDU_IMAGE_SIDE:
            img.thumbnail((MAX_BAIDU_IMAGE_SIDE, MAX_BAIDU_IMAGE_SIDE), Image.LANCZOS)
        output = io.BytesIO()
        img.save(output, format='JPEG', quality=90)
        jpeg_bytes = output.getvalue()
        if len(jpeg_bytes) > MAX_BAIDU_IMAGE_SIZE:
            output = io.BytesIO()
            img.save(output, format='JPEG', quality=70)
            jpeg_bytes = output.getvalue()
        if len(jpeg_bytes) > MAX_BAIDU_IMAGE_SIZE:
            raise ValueError(f'转换后图片仍然过大: {len(jpeg_bytes)} 字节')
        return jpeg_bytes, img.width, img.height


def is_valid_female_face(face: dict, img_area: float, min_face_ratio: float):
    gender = face.get('gender', {})
    face_prob = float(face.get('face_probability', 0.0))
    gender_prob = float(gender.get('probability', 0.0))
    gender_type = str(gender.get('type', '')).lower()
    location = face.get('location', {})
    width = float(location.get('width', 0.0))
    height = float(location.get('height', 0.0))
    face_area_ratio = 0.0
    if width > 0 and height > 0:
        face_area_ratio = (width * height) / img_area

    if face_prob < FACE_PROB_THRESHOLD:
        return False, f'face_prob={face_prob:.2f}低于阈值{FACE_PROB_THRESHOLD}'
    if gender_prob < GENDER_PROB_THRESHOLD:
        return False, f'gender_prob={gender_prob:.2f}低于阈值{GENDER_PROB_THRESHOLD}'
    if gender_type != 'female':
        return False, f'gender_type={gender_type}'
    if face_area_ratio < min_face_ratio:
        return False, f'face_ratio={face_area_ratio:.3f}低于阈值{min_face_ratio}'
    return True, 'OK'


