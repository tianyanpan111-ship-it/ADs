def extract_like_from_initial_state(html: str, note_id: str) -> str:
    if not html:
        return ''

    patterns = []
    if note_id:
        escaped_id = re.escape(note_id)
        patterns.extend([
            rf'"noteId":"{escaped_id}".{{0,5000}}?"interactInfo":\{{[^\{{\}}]*?"likedCount":"?([^",\}}]+)"?',
            rf'"interactInfo":\{{[^\{{\}}]*?"likedCount":"?([^",\}}]+)"?[^\{{\}}]*\}}.{{0,5000}}?"noteId":"{escaped_id}"',
        ])

    patterns.append(r'"interactInfo":\{[^\{\}]*?"likedCount":"?([^",\}]+)"?')

    for pattern in patterns:
        match = re.search(pattern, html, re.S)
        if not match:
            continue
        value = str(match.group(1)).strip()
        if value:
            return value
    return ''


def extract_interact_count_from_initial_state(html: str, note_id: str, key: str) -> str:
    if not html or not key:
        return ''

    patterns = []
    if note_id:
        escaped_id = re.escape(note_id)
        escaped_key = re.escape(key)
        patterns.extend([
            rf'"noteId":"{escaped_id}".{{0,5000}}?"interactInfo":\{{[^\{{\}}]*?"{escaped_key}":"?([^",\}}]+)"?',
            rf'"interactInfo":\{{[^\{{\}}]*?"{escaped_key}":"?([^",\}}]+)"?[^\{{\}}]*\}}.{{0,5000}}?"noteId":"{escaped_id}"',
        ])

    patterns.append(rf'"interactInfo":\{{[^\{{\}}]*?"{re.escape(key)}":"?([^",\}}]+)"?')

    for pattern in patterns:
        match = re.search(pattern, html, re.S)
        if not match:
            continue
        value = str(match.group(1)).strip()
        if value:
            return value
    return ''


def extract_note_field_from_initial_state(html: str, note_id: str, key: str) -> str:
    if not html or not key:
        return ''

    patterns = []
    escaped_key = re.escape(key)
    if note_id:
        escaped_id = re.escape(note_id)
        patterns.extend([
            rf'"noteId":"{escaped_id}".{{0,12000}}?"{escaped_key}":"([^"]+)"',
            rf'"{escaped_key}":"([^"]+)".{{0,12000}}?"noteId":"{escaped_id}"',
        ])

    patterns.append(rf'"{escaped_key}":"([^"]+)"')

    for pattern in patterns:
        match = re.search(pattern, html, re.S)
        if not match:
            continue
        value = str(match.group(1)).strip()
        if value:
            return value.replace('\\n', '\n').replace('\\t', '\t').strip()
    return ''


