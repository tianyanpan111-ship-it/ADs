def run(txt_file_path: str):
    # 登录（如果未登录，请取消注释并手动扫码）
    # sign_in()

    # 读取URL列表
    note_urls = read_urls_from_txt(txt_file_path)
    print(f'共读取 {len(note_urls)} 条笔记链接。')

    # 创建输出目录（以时间戳命名）
    current_time = time.strftime('%Y-%m-%d %H%M%S', time.localtime())
    output_dir = os.path.join(BASE_OUTPUT_ROOT, f'筛选结果_{current_time}')
    os.makedirs(output_dir, exist_ok=True)
    download_dir = os.path.join(output_dir, '下载图片')
    os.makedirs(download_dir, exist_ok=True)

    # 创建浏览器对象（复用）
    note_page = ChromiumPage()
    note_page.set.window.max()

    success_notes = []

    # ========== 异常处理 ==========
    try:
        for idx, note_url in enumerate(tqdm(note_urls, desc='处理笔记')):
            info, success = process_note(note_url, note_page, download_dir, idx)
            if success and info:
                success_notes.append(info)
            if (idx + 1) % BATCH_PAUSE_EVERY == 0:
                sleep_time = random.uniform(BATCH_PAUSE_MIN, BATCH_PAUSE_MAX)
                print(f'已处理 {idx+1} 条笔记，休眠 {sleep_time:.1f} 秒以避免限流。')
                time.sleep(sleep_time)
    except (KeyboardInterrupt, Exception) as e:
        print(f"\n程序异常终止: {e}")
        # 保存已收集的数据
        save_excel_on_interrupt(success_notes, output_dir, current_time)
        # 重新抛出异常，让程序自然退出（也可以注释掉 raise 以避免异常堆栈）
        raise
    finally:
        # 确保浏览器关闭
        note_page.quit()
    # =============================

    if not success_notes:
        print('没有任何含女性人像的笔记，程序结束。')
        return

    # 正常结束时保存Excel
    output_excel = os.path.join(output_dir, f'女性人像笔记_{current_time}.xlsx')
    df = pd.DataFrame(success_notes)
    df.to_excel(output_excel, index=False)
    print(f'已保存 Excel: {output_excel}')
    print(f'已保存图片目录: {download_dir}')


if __name__ == '__main__':
    # 请在此修改txt文件路径
    txt_file_path = r''
