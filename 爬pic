def download_image(url: str, save_dir: str, prefix: str, index: int):
    try:
        headers = {
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36',
            'Referer': 'https://www.xiaohongshu.com/',
        }
        response = requests.get(url, headers=headers, timeout=15)
        response.raise_for_status()
    except Exception as exc:
        print(f'下载失败: {url} -> {exc}')
        return False

    if should_download_image(response.content):
        ext = '.jpeg'
        filename = sanitize_filename(f'{prefix}_{index + 1}{ext}')
        filepath = os.path.join(save_dir, filename)
        with open(filepath, 'wb') as f:
            f.write(response.content)
        print(f'已保存图片: {filepath}')
        return True
    return False


def process_note(note_url: str, note_page, download_dir: str, note_index: int):
    """
    处理单个笔记：
    1. 获取笔记页面
    2. 提取笔记信息（作者、标题、点赞等）
    3. 获取所有图片URL
    4. 对每张图片进行人像检测，下载符合条件的图片
    5. 返回笔记信息字典和是否成功（至少下载了一张图片）
    """
    note_page.get(note_url)
    info = get_note_info(note_page, note_url)
    if not info:
        return None, False

    html = note_page.html
    image_urls = get_pic_urls(html)

    downloaded_urls = []
    for idx, img_url in enumerate(image_urls):
        print(f'正在检测图片 {idx+1}/{len(image_urls)}: {img_url}')
        # 生成前缀：作者名_笔记ID（从URL提取）
        note_id = note_url.rstrip('/').split('/')[-1].split('?')[0]
        prefix = f"{info['作者']}_{note_id}"
        if download_image(img_url, download_dir, prefix, idx):
            downloaded_urls.append(img_url)
        time.sleep(random.uniform(IMAGE_DOWNLOAD_SLEEP_MIN, IMAGE_DOWNLOAD_SLEEP_MAX))

    if downloaded_urls:
        info['图片链接'] = '\n'.join(image_urls)
        info['已下载女性图片链接'] = '\n'.join(downloaded_urls)
        info['已下载图片数量'] = len(downloaded_urls)
        return info, True
    else:
        print(f'跳过笔记（无符合条件图片）: {note_url}')
        return info, False


