def find_column(
    df: pd.DataFrame,
    explicit: Optional[str],
    candidates: Sequence[str],
    kind: str,
) -> str:
    if explicit:
        if explicit not in df.columns:
            raise KeyError(f"Cannot find {kind} column '{explicit}'. Available columns: {df.columns.tolist()}")
        return explicit

    lowered = {str(col).strip().lower(): col for col in df.columns}

    for candidate in candidates:
        for lowered_name, original in lowered.items():
            if candidate.lower() in lowered_name:
                return original

    raise KeyError(f"Cannot auto-detect {kind} column. Available columns: {df.columns.tolist()}")


def sanitize_value(value) -> str:
    if pd.isna(value):
        return ""
    return str(value).strip()


def normalize_text_for_match(text: str) -> str:
    return text.casefold().strip()


def extract_match_candidates(raw_value) -> List[str]:
    """
    Extract the clean image key from the Excel match column.

    Example:
    Excel value:
        6439a70a0000000011011fe9_2?xsec_token=xxx&xsec_source=pc_user

    Clean key:
        6439a70a0000000011011fe9_2

    This clean key will be matched against local image filenames such as:
        兰蔻_6439a70a0000000011011fe9_2.jpg
    """
    text = sanitize_value(raw_value)
    if not text:
        return []

    cleaned = text.split("?")[0].split("#")[0].strip()
    cleaned = cleaned.replace("\\", "/").rsplit("/", 1)[-1].strip()
    cleaned = Path(cleaned).stem

    if not cleaned:
        return []

    return [cleaned]


def list_image_files(image_dir: Path) -> List[Path]:
    files = []

    for path in image_dir.rglob("*"):
        if path.is_file() and path.suffix.lower() in IMAGE_EXTENSIONS:
            files.append(path)

    return sorted(files)


def match_images_to_rows(df: pd.DataFrame, match_col: str, image_dir: Path) -> List[Task]:
    image_files = list_image_files(image_dir)

    if not image_files:
        raise FileNotFoundError(f"No image files found under {image_dir}")

    indexed_images = []
    for path in image_files:
        indexed_images.append(
            {
                "path": path,
                "path_text": normalize_text_for_match(str(path)),
                "name_text": normalize_text_for_match(path.name),
                "stem_text": normalize_text_for_match(path.stem),
            }
        )

    assigned: Dict[str, Task] = {}
    missing_rows: List[int] = []

    for row_index, row in df.iterrows():
        match_value = sanitize_value(row.get(match_col))

        if not match_value:
            missing_rows.append(int(row_index))
            continue

        candidates = [normalize_text_for_match(candidate) for candidate in extract_match_candidates(match_value)]
        candidates = [candidate for candidate in candidates if candidate]

        matched_paths: List[Path] = []
        seen_paths = set()

        for candidate in candidates:
            for item in indexed_images:
                path = item["path"]

                if path in seen_paths:
                    continue

                stem_text = item["stem_text"]
                name_text = item["name_text"]
                path_text = item["path_text"]

                if stem_text.endswith(candidate) or f"_{candidate}" in stem_text:
                    matched_paths.append(path)
                    seen_paths.add(path)
                    continue

                if candidate in name_text or candidate in path_text:
                    matched_paths.append(path)
                    seen_paths.add(path)

        if not matched_paths:
            logging.warning(
                "Row %s matched no images. key=%s | candidates=%s",
                row_index,
                match_value,
                candidates,
            )
            continue

        if len(matched_paths) > 1:
            logging.warning(
                "Row %s matched multiple images. key=%s | candidates=%s | matched=%s",
                row_index,
                match_value,
                candidates,
                [p.name for p in matched_paths],
            )

        for path in matched_paths:
            source_path = str(path.resolve())

            task = Task(
                source_path=source_path,
                image_name=path.name,
                match_key=match_value,
                row_index=int(row_index),
            )

            if source_path not in assigned:
                assigned[source_path] = task
            else:
                prev = assigned[source_path]
                logging.warning(
                    "Duplicate image matched: %s | previous row=%s | current row=%s",
                    path.name,
                    prev.row_index,
                    row_index,
                )

    if missing_rows:
        logging.warning("%d rows had empty match keys.", len(missing_rows))

    tasks = list(assigned.values())
    tasks.sort(key=lambda item: item.image_name.lower())

    return tasks


def ensure_rgb_bytes(image_path: Path) -> bytes:
    from PIL import Image, ImageOps
    import io

    try:
        resample_lanczos = Image.Resampling.LANCZOS
    except AttributeError:
        resample_lanczos = Image.LANCZOS

    with Image.open(image_path) as img:
        img = ImageOps.exif_transpose(img)

        if img.mode != "RGB":
            img = img.convert("RGB")

        max_side = 1600
        if max(img.size) > max_side:
            scale = max_side / float(max(img.size))
            new_size = (
                max(1, int(img.width * scale)),
                max(1, int(img.height * scale)),
            )
            img = img.resize(new_size, resample=resample_lanczos)

        buffer = io.BytesIO()
        img.save(buffer, format="JPEG", quality=92)

        return buffer.getvalue()


def image_bytes_to_data_uri(image_bytes: bytes) -> str:
    encoded = base64.b64encode(image_bytes).decode("ascii")
    return f"data:image/jpeg;base64,{encoded}"


def build_payload(model: str, image_data_uri: str, temperature: float, max_tokens: int) -> Dict:
    user_text = (
        "Please evaluate the female subjectivity shown in this advertising image "
        "based on the scoring rules above. Return JSON only. "
        "Use a 1-7 continuous score with one decimal place and keep the rationale short."
    )

    return {
        "model": model,
        "temperature": temperature,
        "max_tokens": max_tokens,
        "messages": [
            {
                "role": "system",
                "content": SYSTEM_PROMPT,
            },
            {
                "role": "user",
                "content": [
                    {
                        "type": "text",
                        "text": user_text,
                    },
                    {
                        "type": "image_url",
                        "image_url": {
                            "url": image_data_uri,
                        },
                    },
                ],
            },
        ],
    }


def parse_model_json(text: str) -> Dict:
    if not text:
        raise ValueError("Empty model output.")

    text = re.sub(r"```json|```", "", text, flags=re.I).strip()

    m = re.search(r"\{.*\}", text, flags=re.S)
    if not m:
        raise ValueError(f"Cannot locate JSON in model output: {text[:300]}")

    data = json.loads(m.group(0))

    if not isinstance(data, dict):
        raise ValueError("Model output JSON is not an object.")

    return data


def normalize_prediction(data: Dict) -> Dict:
    continuous = data.get("continuous_score", None)
    confidence = data.get("confidence", 0)
    rationale = data.get("rationale", "")

    if continuous is None:
        continuous_score = None
    else:
        try:
            continuous_score = round(float(continuous), 1)
        except Exception:
            continuous_score = None

    if continuous_score is not None:
        if continuous_score < 1 or continuous_score > 7:
            continuous_score = None

    try:
        confidence_value = float(confidence)
    except Exception:
        confidence_value = 0.0

    confidence_value = max(0.0, min(1.0, confidence_value))

    if rationale is None:
        rationale_text = ""
    else:
        rationale_text = str(rationale).strip()

    return {
        "continuous_score": continuous_score,
        "confidence": confidence_value,
        "rationale": rationale_text,
    }


def call_openrouter(
    api_key: str,
    model: str,
    image_path: Path,
    temperature: float,
    max_tokens: int,
    openrouter_referer: str,
    openrouter_title: str,
    retry_times: int,
) -> Dict:
    if not api_key:
        raise ValueError("Missing API key. Please paste your API key into main().")

    image_bytes = ensure_rgb_bytes(image_path)
    image_data_uri = image_bytes_to_data_uri(image_bytes)
    payload = build_payload(model, image_data_uri, temperature, max_tokens)

    headers = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
    }

    if openrouter_referer:
        headers["HTTP-Referer"] = openrouter_referer

    if openrouter_title:
        headers["X-Title"] = openrouter_title

    last_error = None
    attempts = max(1, int(retry_times) + 1)

    for attempt in range(1, attempts + 1):
        try:
            response = requests.post(
                OPENROUTER_CHAT_URL,
                headers=headers,
                json=payload,
                timeout=90,
            )
            response.raise_for_status()

            data = response.json()
            choices = data.get("choices") or []

            if not choices:
                raise ValueError(f"No choices in response: {data}")

            message = choices[0].get("message", {})
            content = message.get("content", "")

            if not isinstance(content, str):
                content = json.dumps(content, ensure_ascii=False)

            parsed = parse_model_json(content)
            return normalize_prediction(parsed)

        except Exception as exc:
            last_error = exc
            logging.warning(
                "API attempt %s/%s failed for %s: %s",
                attempt,
                attempts,
                image_path.name,
                exc,
            )

            if attempt < attempts:
                time.sleep(2 ** attempt)

    raise RuntimeError(f"OpenRouter call failed for {image_path.name}: {last_error}")


def load_checkpoint(checkpoint_path: Path) -> pd.DataFrame:
    if checkpoint_path.exists():
        return pd.read_csv(checkpoint_path)

    return pd.DataFrame()


def save_checkpoint(checkpoint_path: Path, rows: List[Dict]) -> None:
    df = pd.DataFrame(rows)
    df.to_csv(checkpoint_path, index=False, encoding="utf-8-sig")


def build_summary_df(checkpoint_df: pd.DataFrame) -> pd.DataFrame:
    total = len(checkpoint_df)

    if total and "continuous_score" in checkpoint_df.columns:
        scored = int(checkpoint_df["continuous_score"].notna().sum())
    else:
        scored = 0

    error_count = 0
    if "error_message" in checkpoint_df.columns:
        error_series = checkpoint_df["error_message"].fillna("").astype(str)
        error_count = int((error_series.str.strip() != "").sum())

    summary_rows = [
        {
            "metric": "n_images",
            "value": total,
        },
        {
            "metric": "n_with_continuous_score",
            "value": scored,
        },
        {
            "metric": "n_errors",
            "value": error_count,
        },
    ]

    return pd.DataFrame(summary_rows)


def write_outputs(
    output_dir: Path,
    prefix: str,
    input_df: pd.DataFrame,
    checkpoint_df: pd.DataFrame,
) -> Tuple[Path, Path, Path]:
    result_csv = output_dir / f"{prefix}_predictions.csv"
    result_xlsx = output_dir / f"{prefix}_predictions.xlsx"
    summary_csv = output_dir / f"{prefix}_summary.csv"

    annotated_df = input_df.copy()

    annotated_df["LLM_image"] = ""
    annotated_df["LLM_continuous_score"] = pd.NA
    annotated_df["LLM_confidence"] = pd.NA
    annotated_df["LLM_rationale"] = ""
    annotated_df["LLM_error_message"] = ""

    for _, row in checkpoint_df.iterrows():
        row_index = row.get("row_index")

        if pd.isna(row_index):
            continue

        row_index = int(row_index)

        if row_index not in annotated_df.index:
            continue

        annotated_df.loc[row_index, "LLM_image"] = row.get("image", "")
        annotated_df.loc[row_index, "LLM_continuous_score"] = row.get("continuous_score", pd.NA)
        annotated_df.loc[row_index, "LLM_confidence"] = row.get("confidence", pd.NA)
        annotated_df.loc[row_index, "LLM_rationale"] = row.get("rationale", "")
        annotated_df.loc[row_index, "LLM_error_message"] = row.get("error_message", "")

    summary_df = build_summary_df(checkpoint_df)

    annotated_df.to_csv(result_csv, index=False, encoding="utf-8-sig")
    summary_df.to_csv(summary_csv, index=False, encoding="utf-8-sig")

    with pd.ExcelWriter(result_xlsx, engine="openpyxl") as writer:
        annotated_df.to_excel(writer, sheet_name="input_with_llm_annotations", index=False)
        summary_df.to_excel(writer, sheet_name="summary", index=False)
        checkpoint_df.to_excel(writer, sheet_name="evaluation_pairs", index=False)

    return result_csv, result_xlsx, summary_csv


def main() -> None:
    api_key = ""

    args = parse_args()

    input_excel = Path(args.input_excel)
    image_dir = Path(args.image_dir)
    output_dir = Path(args.output_dir)

    output_dir.mkdir(parents=True, exist_ok=True)
    setup_logging(output_dir)

    if not input_excel.exists():
        raise FileNotFoundError(f"Input Excel not found: {input_excel}")

    if not image_dir.exists():
        raise FileNotFoundError(f"Image directory not found: {image_dir}")

    prefix = args.output_prefix or input_excel.stem

    checkpoint_path = output_dir / f"{prefix}_checkpoint.csv"
    error_log_path = output_dir / f"{prefix}_errors.csv"

    df = read_excel_dataframe(input_excel, args.sheet_name)
    match_col = find_column(df, args.match_col, DEFAULT_MATCH_CANDIDATES, "match key")

    logging.info("Input rows: %s", len(df))
    logging.info("Using match column: %s", match_col)

    tasks = match_images_to_rows(df, match_col, image_dir)
    logging.info("Matched unique images: %s", len(tasks))

    checkpoint_df = load_checkpoint(checkpoint_path)

    if checkpoint_df.empty:
        checkpoint_rows: List[Dict] = []
    else:
        checkpoint_rows = checkpoint_df.to_dict(orient="records")

    processed_paths = set()

    if not checkpoint_df.empty and "source_path" in checkpoint_df.columns:
        processed_paths = set(checkpoint_df["source_path"].dropna().astype(str).tolist())

    logging.info("Already processed images: %s", len(processed_paths))

    errors: List[Dict] = []

    for index, task in enumerate(tasks, start=1):
        if task.source_path in processed_paths:
            logging.info("Skip %s (%s/%s)", task.image_name, index, len(tasks))
            continue

        image_path = Path(task.source_path)

        logging.info("Processing %s (%s/%s)", task.image_name, index, len(tasks))

        try:
            prediction = call_openrouter(
                api_key=api_key,
                model=args.model,
                image_path=image_path,
                temperature=args.temperature,
                max_tokens=args.max_tokens,
                openrouter_referer=args.openrouter_referer,
                openrouter_title=args.openrouter_title,
                retry_times=args.retry_times,
            )

            row = {
                "source_path": task.source_path,
                "image": task.image_name,
                "match_key": task.match_key,
                "row_index": task.row_index,
                "continuous_score": prediction["continuous_score"],
                "confidence": prediction["confidence"],
                "rationale": prediction["rationale"],
                "error_message": "",
            }

            checkpoint_rows.append(row)
            processed_paths.add(task.source_path)

            time.sleep(0.8)

        except Exception as exc:
            error_message = str(exc)

            logging.exception("Failed on %s", task.image_name)

            error_row = {
                "source_path": task.source_path,
                "image": task.image_name,
                "match_key": task.match_key,
                "row_index": task.row_index,
                "continuous_score": None,
                "confidence": 0.0,
                "rationale": "",
                "error_message": error_message,
            }

            errors.append(error_row)
            checkpoint_rows.append(error_row)

        save_checkpoint(checkpoint_path, checkpoint_rows)

    if errors:
        pd.DataFrame(errors).to_csv(error_log_path, index=False, encoding="utf-8-sig")
        logging.info("Wrote error log: %s", error_log_path)

    checkpoint_df = pd.DataFrame(checkpoint_rows)

    if checkpoint_df.empty:
        logging.warning("No images were processed, nothing to export.")
        return

    checkpoint_df["continuous_score"] = pd.to_numeric(
        checkpoint_df.get("continuous_score"),
        errors="coerce",
    )

    checkpoint_df["confidence"] = pd.to_numeric(
        checkpoint_df.get("confidence"),
        errors="coerce",
    ).fillna(0.0)

    checkpoint_df["rationale"] = checkpoint_df.get("rationale", "").fillna("").astype(str)
    checkpoint_df["image"] = checkpoint_df.get("image", "").fillna("").astype(str)

    if "error_message" not in checkpoint_df.columns:
        checkpoint_df["error_message"] = ""

    result_csv, result_xlsx, summary_csv = write_outputs(
        output_dir=output_dir,
        prefix=prefix,
        input_df=df,
        checkpoint_df=checkpoint_df,
    )

    logging.info("Final predictions CSV: %s", result_csv)
    logging.info("Final predictions Excel: %s", result_xlsx)
    logging.info("Summary CSV: %s", summary_csv)
    logging.info("Checkpoint CSV: %s", checkpoint_path)


if __name__ == "__main__":
    main()
