# =========================
# face detection (Baidu)
# =========================
def baidu_face_ratio(img_path):

    global access_token
    if access_token is None:
        get_token()

    with open(img_path, "rb") as f:
        img_base64 = base64.b64encode(f.read()).decode()

    url = f"https://aip.baidubce.com/rest/2.0/face/v3/detect?access_token={access_token}"

    payload = {
        "image": img_base64,
        "image_type": "BASE64",
        "face_field": "location",
        "max_face_num": 10
    }

    try:
        res = requests.post(url, json=payload, timeout=20)
        data = res.json()

        if data.get("error_code", 0) != 0:
            return np.nan, np.nan

        faces = data["result"]["face_list"]

        img = Image.open(img_path)
        w, h = img.size

        total_area = 0
        face_count = len(faces)

        for face in faces:
            loc = face["location"]
            bw = loc["width"]
            bh = loc["height"]
            total_area += bw * bh

        return total_area / (w * h), face_count

    except Exception:
        return np.nan, np.nan


# =========================
# CV features
# =========================
def brightness(img):
    return np.mean(cv2.cvtColor(img, cv2.COLOR_BGR2GRAY))


def contrast(img):
    return np.std(cv2.cvtColor(img, cv2.COLOR_BGR2GRAY))


def colorfulness(img):
    (B, G, R) = cv2.split(img.astype("float"))
    rg = np.abs(R - G)
    yb = np.abs(0.5 * (R + G) - B)
    return np.sqrt(np.std(rg) ** 2 + np.std(yb) ** 2)


# =========================
# ORIGINAL complexity (Canny version)
# =========================
def visual_complexity(img):
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
    edges = cv2.Canny(gray, 100, 200)
    return np.mean(edges)


def background_complexity(img):
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
    h, w = gray.shape

    crop = gray[int(h * 0.2):int(h * 0.8), int(w * 0.2):int(w * 0.8)]
    edges = cv2.Canny(crop, 100, 200)

    return np.mean(edges)


# =========================
# image resolution
# =========================
def image_resolution(img):
    h, w = img.shape[:2]
    return h * w


# =========================
# skin exposure
# =========================
def skin_exposure(img):
    hsv = cv2.cvtColor(img, cv2.COLOR_BGR2HSV)

    lower = np.array([0, 30, 60])
    upper = np.array([25, 180, 255])

    mask = cv2.inRange(hsv, lower, upper)

    return np.sum(mask > 0) / (img.shape[0] * img.shape[1])


# =========================
# image matching
# =========================
def normalize_key(text):
    if pd.isna(text):
        return []

    stem = Path(str(text).strip()).stem
    stem = stem.split("?")[0].split("#")[0]
    stem = stem.lstrip("_")

    candidates = [stem]

    if "_" in stem:
        candidates.append(stem.split("_", 1)[1])

    return list(dict.fromkeys(candidates))


def build_image_index(image_files):
    image_index = {}

    for file_path in image_files:
        stem = Path(file_path).stem
        image_index[stem] = str(file_path)
        image_index[stem.lstrip("_")] = str(file_path)

    return image_index


def match_image(name, image_index):
    for candidate in normalize_key(name):
        if candidate in image_index:
            return image_index[candidate]
    return None


def read_image(path):
    image_data = np.fromfile(path, dtype=np.uint8)
    if image_data.size == 0:
        return None
    return cv2.imdecode(image_data, cv2.IMREAD_COLOR)


