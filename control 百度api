def get_token():
    global access_token

    url = "https://aip.baidubce.com/oauth/2.0/token"
    params = {
        "grant_type": "client_credentials",
        "client_id": API_KEY,
        "client_secret": SECRET_KEY
    }

    res = requests.get(url, params=params, timeout=15)
    res.raise_for_status()
    data = res.json()

    access_token = data["access_token"]


