def detect_lottery(title, content):
    text = ""

    if pd.notna(title):
        text += str(title)

    if pd.notna(content):
        text += str(content)

    keywords = ["宠粉", "福利", "抽奖", "惊喜盒子", "免费领", "🎁"]

    return 1 if any(k in text for k in keywords) else 0


