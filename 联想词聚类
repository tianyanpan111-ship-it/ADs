import argparse
import os
import re
from typing import List, Optional, Tuple

import jieba
import pandas as pd
from sklearn.decomposition import LatentDirichletAllocation
from sklearn.feature_extraction.text import CountVectorizer


DEFAULT_INPUT = r"D:\研究生\论文\女性广告\实验\气质女性特征分析.xlsx"
DEFAULT_OUTPUT = r"D:\研究生\论文\女性广告\实验\气质女性特征分析_LDA结果.xlsx"

DEFAULT_STOPWORDS = {
    "的",
    "了",
    "和",
    "是",
    "在",
    "就",
    "都",
    "而",
    "及",
    "与",
    "着",
    "也",
    "很",
    "还",
    "一个",
    "没有",
    "我们",
    "你们",
    "他们",
    "她们",
    "这个",
    "那个",
}


def load_stopwords(stopwords_path: Optional[str] = None) -> set:
    stopwords = set(DEFAULT_STOPWORDS)
    if stopwords_path and os.path.exists(stopwords_path):
        with open(stopwords_path, "r", encoding="utf-8") as file_obj:
            for line in file_obj:
                word = line.strip()
                if word:
                    stopwords.add(word)
    return stopwords


def split_phrases(cell_value) -> List[str]:
    if pd.isna(cell_value):
        return []
    text = str(cell_value).strip()
    if not text:
        return []
    return [part.strip() for part in re.split(r"\s+", text) if part.strip()]


def tokenize_text(text: str, stopwords: set) -> List[str]:
    tokens = []
    for token in jieba.lcut(text):
        token = token.strip()
        if not token:
            continue
        if token in stopwords:
            continue
        if len(token) == 1 and not token.isalnum():
            continue
        tokens.append(token)
    return tokens


def build_documents(df: pd.DataFrame, column_name: str, stopwords: set) -> pd.DataFrame:
    records = []
    for row_index, value in df[column_name].items():
        phrases = split_phrases(value)
        for phrase_index, phrase in enumerate(phrases, start=1):
            tokens = tokenize_text(phrase, stopwords)
            if not tokens:
                continue
            records.append(
                {
                    "source_row": row_index + 2,
                    "phrase_index": phrase_index,
                    "phrase": phrase,
                    "tokens": " ".join(tokens),
                }
            )
    return pd.DataFrame(records)


def run_lda(doc_df: pd.DataFrame, topic_num: int, top_words: int) -> Tuple[pd.DataFrame, pd.DataFrame]:
    if doc_df.empty:
        raise ValueError("没有可用于 LDA 的文本，检查 asso 列是否为空或是否分词后都被过滤掉了。")

    vectorizer = CountVectorizer(
        tokenizer=str.split,
        preprocessor=None,
        token_pattern=None,
        lowercase=False,
    )
    doc_term_matrix = vectorizer.fit_transform(doc_df["tokens"])

    lda = LatentDirichletAllocation(
        n_components=topic_num,
        random_state=42,
        learning_method="batch",
    )
    topic_distribution = lda.fit_transform(doc_term_matrix)

    topic_columns = [f"topic_{i}" for i in range(topic_num)]
    topic_df = pd.DataFrame(topic_distribution, columns=topic_columns)
    topic_strength = topic_df.mean(axis=0)
    result_df = doc_df.copy()
    result_df["dominant_topic"] = topic_df.idxmax(axis=1).str.replace("topic_", "", regex=False).astype(int)
    result_df["topic_prob"] = topic_df.max(axis=1)

    feature_names = vectorizer.get_feature_names_out()
    topic_rows = []
    for topic_id, topic_weights in enumerate(lda.components_):
        top_indices = topic_weights.argsort()[::-1][:top_words]
        topic_rows.append(
            {
                "topic_id": topic_id,
                "top_words": " ".join(feature_names[index] for index in top_indices),
                "topic_strength": float(topic_strength[f"topic_{topic_id}"]),
            }
        )
    topic_words_df = pd.DataFrame(topic_rows)
    topic_words_df = topic_words_df.sort_values(by="topic_strength", ascending=False).reset_index(drop=True)

    return result_df, topic_words_df


def main() -> None:
    parser = argparse.ArgumentParser(description="对 Excel 中 asso 列的短语/句子做中文 LDA 主题聚类。")
    parser.add_argument("--input", default=DEFAULT_INPUT, help="输入 Excel 路径")
    parser.add_argument("--output", default=DEFAULT_OUTPUT, help="输出 Excel 路径")
    parser.add_argument("--column", default="asso", help="要分析的列名")
    parser.add_argument("--topics", type=int, default=7, help="LDA 主题数")
    parser.add_argument("--top-words", type=int, default=10, help="每个主题输出的高频词数")
    parser.add_argument("--stopwords", default=None, help="可选停用词文件路径")
    args = parser.parse_args()

    df = pd.read_excel(args.input)
    if args.column not in df.columns:
        raise KeyError(f"找不到列 {args.column}，当前列名为：{df.columns.tolist()}")

    stopwords = load_stopwords(args.stopwords)
    doc_df = build_documents(df, args.column, stopwords)
    result_df, topic_words_df = run_lda(doc_df, args.topics, args.top_words)

    with pd.ExcelWriter(args.output, engine="openpyxl") as writer:
        result_df.to_excel(writer, sheet_name="phrase_topics", index=False)
        topic_words_df.to_excel(writer, sheet_name="topic_words", index=False)

    print(f"已完成 LDA 聚类，结果保存到：{args.output}")
    print("主题词如下：")
    for _, row in topic_words_df.iterrows():
        print(f"Topic {int(row['topic_id'])} | 强度={row['topic_strength']:.4f}: {row['top_words']}")


if __name__ == "__main__":
    main()
